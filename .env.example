# ── LLM Configuration ──
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# ── AWS Polly TTS ──
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-2
POLLY_VOICE=Olivia
POLLY_ENGINE=neural

# ── Keycloak OIDC Authentication ──
# Leave KEYCLOAK_URL empty to disable authentication
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=grover
KEYCLOAK_CLIENT_ID=grover-web
AUTH_SESSION_TTL=86400000

# Browser-facing Keycloak URL (when running in Docker, the browser reaches
# Keycloak via localhost, not the Docker service name)
KEYCLOAK_PUBLIC_URL=http://localhost:8080

# Keycloak admin credentials (for admin API proxy)
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# ── API Key Authentication ──
# Set to enable Bearer token auth for external service-to-service calls
# Usage: curl -H "Authorization: Bearer <key>" http://localhost:3000/api/ask
GROVER_API_KEY=

# ── CORS ──
# Override the default CORS origin (defaults to http://localhost:<port>)
CORS_ORIGIN=http://localhost:3000

# ── PostgreSQL ──
POSTGRES_PASSWORD=grover
DATABASE_URL=postgres://grover:grover@localhost:5432/grover

# ── Debug ──
# NODE_DEBUG=http
